# Copy this file to .env before starting the backend.
# Replace YOUR_MYSQL_PASSWORD with the password of your local MySQL root user.
DATABASE_URL=mysql+pymysql://root:YOUR_MYSQL_PASSWORD@127.0.0.1:3306/adaptive_math_ai?charset=utf8mb4

# Optional. Leave empty to use built-in template questions and local hints.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# auto = seed demo data only when the database is empty
SEED_DEMO_DATA=auto
